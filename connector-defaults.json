  "standards": {
    "smacna-seal-class-c-seed": {
      "label": "SMACNA Seed - Seal Class C",
      "source": "SMACNA-style seed default",
      "description": "Starter rule set for connector material takeoff. Quantities and allowed products must be reviewed against the actual project specification before use.",
      "rules": [
        {
          "id": "round-spiral-joint-mastic",
          "label": "Round/Oval/Spiral Joint Mastic",
          "product": "water-based-duct-mastic",
          "appliesToShapes": ["spiral", "round", "oval"],
          "appliesToJointTypes": ["duct-fitting", "fitting-fitting", "duct-duct"],
          "quantityFormula": "jointLengthFt / coveragePerUnit * wasteFactor",
          "jointLengthFormula": "circumferenceFt",
          "enabled": true
        },
        {
          "id": "rect-joint-mastic",
          "label": "Rectangular Joint Mastic",
          "product": "water-based-duct-mastic",
          "appliesToShapes": ["rect"],
          "appliesToJointTypes": ["duct-fitting", "fitting-fitting", "duct-duct"],
          "quantityFormula": "jointLengthFt / coveragePerUnit * wasteFactor",
          "jointLengthFormula": "perimeterFt",
          "enabled": true
        },
        {
          "id": "rect-joint-tape",
          "label": "Rectangular Joint Tape",
          "product": "foil-scrim-kraft-tape",
          "appliesToShapes": ["rect"],
          "appliesToJointTypes": ["slip-drive", "duct-fitting", "fitting-fitting", "duct-duct"],
          "quantityFormula": "jointLengthFt / coveragePerUnit * wasteFactor",
          "jointLengthFormula": "perimeterFt",
          "enabled": false,
          "notes": "Use only where the project specification allows a listed tape closure/sealing system. Not a default replacement for mastic in higher SMACNA seal classes."
        },
        {
          "id": "rect-s-cleat-slip",
          "label": "Rectangular S-Cleats (Slip)",
          "product": "rect-s-cleat-slip",
          "appliesToShapes": ["rect"],
          "appliesToJointTypes": ["slip-drive", "duct-fitting", "fitting-fitting", "duct-duct"],
          "quantityFormula": "jointLengthFt / coveragePerUnit * wasteFactor",
          "jointLengthFormula": "opposingSidesFt",
          "enabled": true
        },
        {
          "id": "rect-drive-cleat",
          "label": "Rectangular Drive Cleats",
          "product": "rect-drive-cleat",
          "appliesToShapes": ["rect"],
          "appliesToJointTypes": ["slip-drive", "duct-fitting", "fitting-fitting", "duct-duct"],
          "quantityFormula": "jointLengthFt / coveragePerUnit * wasteFactor",
          "jointLengthFormula": "opposingSidesFt",
          "enabled": true
        },
        {
          "id": "rect-flange-gasket",
          "label": "Rectangular Flange Gasket",
          "product": "butyl-gasket-tape",
          "appliesToShapes": ["rect"],
          "appliesToJointTypes": ["flange"],
          "quantityFormula": "jointLengthFt / coveragePerUnit * wasteFactor",
          "jointLengthFormula": "perimeterFt",
          "enabled": false
        },
        {
          "id": "mechanical-fastener-allowance",
          "label": "Mechanical Fastener Allowance",
          "product": "sheet-metal-screws",
          "appliesToShapes": ["spiral", "round", "rect", "oval"],
          "appliesToJointTypes": ["duct-fitting", "duct-duct", "fitting-fitting"],
          "quantityFormula": "ceil(jointLengthFt / spacingFt) * wasteFactor",
          "spacingFt": 0.5,
          "enabled": false
        }
      ]
    }
  }
}
