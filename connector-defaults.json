{
  "_meta": {
    "version": "0.1.0",
    "lastUpdated": "2026-05-17",
    "description": "Connector and joint product defaults for IS Plan Viewer. These are seed construction-standard rules for consumables applied to duct and fitting joints. Project/company overrides and the future Standards tool should take priority.",
    "units": {
      "jointLength": "LF",
      "coverageLength": "LF per material unit",
      "materialCost": "$ per material unit",
      "labor": "hrs per application unit"
    }
  },
  "takeoffDefaults": {
    "activeStandard": "smacna-seal-class-c-seed",
    "autoFittingsDefaults": {
      "spiral": true,
      "round": false,
      "rect": false,
      "oval": false,
      "flex": false
    },
    "defaultWasteFactor": 1.1,
    "roundJointLengthFormula": "circumferenceFt",
    "rectJointLengthFormula": "perimeterFt",
    "ovalJointLengthFormula": "approxOvalPerimeterFt",
    "showInCompiler": true,
    "showInCanvas": false,
    "description": "Connector quantities are calculated from duct/fitting connection joints and are intended to be reviewed in the future standalone Construction Standards tool."
  },
